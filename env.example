# MangaPlus React App - Environment Configuration

# API Configuration
REACT_APP_API_BASE=https://api.mangaplus.shueisha.co.jp/v2

# Analytics (Optional)
REACT_APP_GOOGLE_ANALYTICS_ID=

# Feature Flags
REACT_APP_ENABLE_ADS=true
REACT_APP_ENABLE_COMMENTS=false
REACT_APP_ENABLE_SOCIAL_SHARE=true

# App Settings
REACT_APP_ITEMS_PER_PAGE=30
REACT_APP_CACHE_TIMEOUT=3600000
REACT_APP_MAX_BOOKMARK_SUGGESTIONS=10

# Third-party Services (Optional)
REACT_APP_STRIPE_PUBLIC_KEY=
REACT_APP_FIREBASE_API_KEY=
REACT_APP_FIREBASE_PROJECT_ID=

# Development
REACT_APP_DEBUG_MODE=false
REACT_APP_LOG_API_CALLS=false
